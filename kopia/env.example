# Copy to ~/.config/kopia/env (mode 600) and fill in.
#
#   install -m 600 ~/.dotfiles/kopia/env.example ~/.config/kopia/env
#   $EDITOR ~/.config/kopia/env

# Required. Must match the password used by your remote sync (e.g. a k8s
# SOPS secret). Losing this = losing backups, so keep a copy in your
# password manager.
KOPIA_PASSWORD=

# Required. SFTP target for snapshots.
KOPIA_SFTP_HOST=
KOPIA_SFTP_BASE=

# Optional overrides.
# KOPIA_SFTP_PORT=22
# KOPIA_SFTP_USER=kopia
