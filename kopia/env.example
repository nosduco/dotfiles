# Copy to ~/.config/kopia/env (mode 600) and fill in.
#
#   install -m 600 ~/.dotfiles/kopia/env.example ~/.config/kopia/env
#   $EDITOR ~/.config/kopia/env

# Required. Must match KOPIA_PASSWORD in tux-infra's
# platform/kopia-endpoints-sync SOPS secret. Losing this = losing backups,
# so keep a copy in your password manager.
KOPIA_PASSWORD=

# Optional overrides (defaults in bootstrap-repos.sh).
# Uncomment + set only if this machine diverges from the homelab default.
# KOPIA_SFTP_HOST=tux
# KOPIA_SFTP_PORT=22
# KOPIA_SFTP_USER=kopia
# KOPIA_SFTP_BASE=/tank/data/backups/endpoints
# KOPIA_SSH_KEYFILE=$HOME/.ssh/id_ed25519
# KOPIA_SSH_KNOWN_HOSTS=$HOME/.ssh/known_hosts
